  ] [plot 0]

  set-current-plot-pen "CharactrAI"
  ifelse any? products with [product-name = "CharactrAI" and is-alive] [
    plot [user-base] of one-of products with [product-name = "CharactrAI" and is-alive]
  ] [plot 0]

  set-current-plot "Domestic vs International"
  set-current-plot-pen "Domestic-Total"
  plot sum [user-base] of products with [product-origin = "domestic" and is-alive]

  set-current-plot-pen "International-Total"
  plot sum [user-base] of products with [product-origin = "international" and is-alive]

  set-current-plot "Survival Count"
  set-current-plot-pen "Alive"
  plot count products with [is-alive]
end
